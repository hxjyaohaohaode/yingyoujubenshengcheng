# 互动影游剧本智能体集群 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# PostgreSQL 数据库连接
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/script_engine
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/script_engine

# Redis 连接
REDIS_URL=redis://localhost:6379/0

# DeepSeek API（创作Agent + 审计Agent + 伏笔Agent + 创意Agent + 编排Agent）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# MiMo API（状态Agent + 素材Agent）
MIMO_API_KEY=your-mimo-api-key
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# 应用密钥（生产环境务必修改）
SECRET_KEY=change-me-to-a-random-secret-key-in-production

# Git 仓库路径（用于剧本版本控制）
GIT_REPO_PATH=./data/repos

# CORS 允许的前端地址（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 运行环境: development / production
APP_ENV=development
